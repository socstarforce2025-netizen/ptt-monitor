<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PTT 關鍵字監控"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="監控看板（逗號分隔）" android:layout_marginBottom="4dp"/>
        <EditText
            android:id="@+id/etBoards"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e-coupon,Lifeismoney"
            android:inputType="text"
            android:layout_marginBottom="12dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="關鍵字（逗號分隔）" android:layout_marginBottom="4dp"/>
        <EditText
            android:id="@+id/etKeywords"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="衛生紙,面紙"
            android:inputType="text"
            android:layout_marginBottom="12dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Line Notify Token" android:layout_marginBottom="4dp"/>
        <EditText
            android:id="@+id/etLineToken"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="（選填）貼上你的 Line Notify Token"
            android:inputType="text"
            android:layout_marginBottom="12dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="檢查間隔（分鐘）" android:layout_marginBottom="4dp"/>
        <EditText
            android:id="@+id/etInterval"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="5"
            android:inputType="number"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="儲存設定"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnStart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="▶ 開始監控"
            android:backgroundTint="#4CAF50"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnStop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⏹ 停止監控"
            android:backgroundTint="#F44336"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔴 已停止"
            android:textSize="18sp"
            android:gravity="center"/>

    </LinearLayout>
</ScrollView>
